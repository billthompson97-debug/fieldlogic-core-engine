{
  "name": "fieldlogic-core-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply FIELDLOGIC_DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply FIELDLOGIC_DB --remote",
    "smoke": "node scripts/smoke-test.mjs"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "typescript": "latest",
    "wrangler": "latest"
  }
}
